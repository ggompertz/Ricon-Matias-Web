---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <img src={`${base}/images/site/logo.png`} alt="Rincón de Matías" height="48" />
      <p class="footer__slogan">Para los niños —<br/>y también — para los papás.</p>
    </div>

    <nav class="footer__nav" aria-label="Navegación footer">
      <strong>Páginas</strong>
      <a href={`${base}/`}>Inicio</a>
      <a href={`${base}/nosotros`}>Nosotros</a>
      <a href={`${base}/ciclos`}>Ciclos</a>
      <a href={`${base}/para-papas`}>Para los papás</a>
      <a href={`${base}/contacto`}>Contacto</a>
    </nav>

    <div class="footer__contacto">
      <strong>Contacto</strong>
      <p>Av. Concón Reñaca 66, Concón</p>
      <p>Lun–Jue 7:30–18:00 · Vie 7:30–17:30</p>
      <a href="tel:+56XXXXXXXXX">+56 X XXXX XXXX</a>
      <a href="mailto:rincondematias@gmail.com">rincondematias@gmail.com</a>
      <a href="https://instagram.com/rincondematias" target="_blank" rel="noopener" class="footer__instagram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        @rincondematias
      </a>
    </div>
  </div>

  <div class="footer__bottom container">
    <p>© {new Date().getFullYear()} Rincón de Matías · RBD 41528-6</p>
    <a href={`${base}/admin`} class="footer__admin">Admin</a>
  </div>
</footer>

<style>
  .footer {
    background: var(--cafe);
    color: var(--crema);
    padding: 3.5rem 0 1.5rem;
    margin-top: 0;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr;
    gap: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,.1);
  }

  .footer__brand img { margin-bottom: .75rem; }
  .footer__slogan {
    font-family: var(--font-mano);
    font-size: 1.2rem;
    opacity: .75;
    line-height: 1.4;
  }

  .footer__nav, .footer__contacto {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .footer__nav strong,
  .footer__contacto strong {
    font-family: var(--font-titulo);
    font-size: 1rem;
    margin-bottom: .25rem;
    color: var(--amarillo);
  }
  .footer__nav a,
  .footer__contacto a,
  .footer__contacto p {
    font-size: .9rem;
    opacity: .75;
    transition: opacity .15s;
  }
  .footer__nav a:hover,
  .footer__contacto a:hover { opacity: 1; }

  .footer__instagram {
    display: flex;
    align-items: center;
    gap: .4rem;
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.25rem;
    font-size: .8rem;
    opacity: .5;
  }
  .footer__admin { opacity: .3; }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>

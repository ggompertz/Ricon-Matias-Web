---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const links = [
  { href: `${base}/nosotros`,   label: 'Nosotros' },
  { href: `${base}/ciclos`,     label: 'Ciclos' },
  { href: `${base}/para-papas`, label: 'Para los papás' },
  { href: `${base}/contacto`,   label: 'Contacto' },
];

const pathname = Astro.url.pathname;
---

<header class="nav">
  <div class="nav__inner container">
    <a href={`${base}/`} class="nav__logo" aria-label="Rincón de Matías — inicio">
      <img src={`${base}/images/site/logo.png`} alt="Rincón de Matías" height="44" />
    </a>

    <nav class="nav__links" aria-label="Menú principal">
      {links.map(l => (
        <a
          href={l.href}
          class={`nav__link${pathname.startsWith(l.href) ? ' nav__link--active' : ''}`}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <a href={`${base}/contacto#agendar`} class="btn btn--amarillo nav__cta">
      Agendar visita
    </a>

    <button class="nav__burger" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Menú móvil -->
  <div class="nav__mobile" id="mobile-menu" hidden>
    {links.map(l => (
      <a href={l.href} class="nav__mobile-link">{l.label}</a>
    ))}
    <a href={`${base}/contacto#agendar`} class="btn btn--amarillo">Agendar visita</a>
  </div>
</header>

<script>
  const burger = document.querySelector('.nav__burger') as HTMLButtonElement;
  const menu   = document.getElementById('mobile-menu') as HTMLElement;

  burger?.addEventListener('click', () => {
    const open = menu.hidden;
    menu.hidden = !open;
    burger.setAttribute('aria-expanded', String(open));
    burger.classList.toggle('nav__burger--open', open);
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    inset-inline: 0;
    z-index: 100;
    background: var(--crema);
    border-bottom: 2px solid var(--crema-2);
    height: var(--nav-h);
  }

  .nav__inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav__logo img { height: 44px; width: auto; }

  .nav__links {
    display: flex;
    gap: 1.75rem;
    margin-left: auto;
  }

  .nav__link {
    font-family: var(--font-titulo);
    font-weight: 500;
    font-size: 1rem;
    color: var(--cafe);
    opacity: .8;
    transition: opacity .15s;
  }
  .nav__link:hover,
  .nav__link--active { opacity: 1; color: var(--naranja); }

  .nav__cta { margin-left: 1rem; }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: .5rem;
    margin-left: auto;
  }
  .nav__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--cafe);
    border-radius: 2px;
    transition: transform .2s, opacity .2s;
  }
  .nav__burger--open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__burger--open span:nth-child(2) { opacity: 0; }
  .nav__burger--open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav__mobile {
    background: var(--crema);
    padding: 1rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 1px solid var(--crema-2);
  }
  .nav__mobile-link {
    font-family: var(--font-titulo);
    font-size: 1.1rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .nav__links, .nav__cta { display: none; }
    .nav__burger { display: flex; }
  }
</style>

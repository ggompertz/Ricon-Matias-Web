---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Nosotros"
  description="30 años cuidando niños en Concón. Conoce la historia, el equipo y los valores que hacen de Rincón de Matías un jardín infantil distinto."
>
  <Nav slot="nav" />

  <!-- ── HERO ── -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <div>
        <span class="section__badge">Desde 1994</span>
        <h1 class="page-hero__h1">Tres décadas cuidando lo que importa</h1>
        <p class="page-hero__sub">
          Rincón de Matías nació en Concón con una convicción simple: los niños crecen mejor
          cuando sus familias están tranquilas. Eso no ha cambiado en 30 años.
        </p>
      </div>
      <div class="page-hero__img">
        <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/images/site/nosotros-hero.png`} alt="Rincón de Matías — equipo y niños" />
      </div>
    </div>
  </section>

  <!-- ── HISTORIA ── -->
  <section class="section section--crema2">
    <div class="container historia">
      <div class="historia__texto">
        <span class="section__badge">Nuestra historia</span>
        <h2 class="section__titulo">Un jardín que creció con Concón</h2>
        <p>
          Abrimos nuestras puertas en 1994 en Av. Concón Reñaca 66, cuando Concón era una ciudad
          distinta. Lo que no cambió es el barrio, la dirección y la convicción de que cada niño
          merece un espacio propio para crecer.
        </p>
        <p>
          A lo largo de los años incorporamos dos ciclos educativos — Sala Cuna y Jardín Infantil —
          ampliamos los espacios, sumamos profesionales y ajustamos los horarios a la realidad
          de las familias trabajadoras de hoy. Pero el espíritu del jardín sigue siendo el mismo.
        </p>
        <p>
          Más de 30 generaciones de niños pasaron por nuestras salas.
          Algunos ya traen a sus propios hijos.
        </p>
      </div>
      <div class="historia__hitos">
        {[
          { año: '1994', hito: 'Apertura en Av. Concón Reñaca 66' },
          { año: '2000', hito: 'Incorporación de Sala Cuna' },
          { año: '2010', hito: 'Ampliación de salas y patios' },
          { año: '2020', hito: 'Jornada extendida Lun–Jue hasta 18:00' },
          { año: 'Hoy',  hito: '30 años · 2 ciclos · 4 salas · 2 accesos' },
        ].map(h => (
          <div class="historia__hito">
            <span class="historia__año">{h.año}</span>
            <span class="historia__linea"></span>
            <p>{h.hito}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── VALORES ── -->
  <section class="section section--crema">
    <div class="container">
      <div class="section__header">
        <span class="section__badge">Lo que nos guía</span>
        <h2 class="section__titulo">Nuestros valores</h2>
      </div>
      <div class="valores__grid">
        {[
          { icono: '🌱', color: 'var(--verde)',   titulo: 'Respeto por los tiempos',     desc: 'Cada niño tiene su propio ritmo. No apuramos ni comparamos. Acompañamos.' },
          { icono: '🤝', color: 'var(--azul)',    titulo: 'Alianza con las familias',    desc: 'El jardín y la familia son un equipo. La comunicación es constante y honesta.' },
          { icono: '💛', color: 'var(--amarillo)', titulo: 'Calidez real',               desc: 'No es un slogan. Es la forma en que recibimos, cuidamos y despedimos cada día.' },
          { icono: '🔍', color: 'var(--naranja)', titulo: 'Intención educativa',        desc: 'Cada actividad tiene un propósito. El juego es aprendizaje y lo sabemos.' },
          { icono: '🏡', color: 'var(--rosa)',    titulo: 'Sentido de pertenencia',     desc: 'Los niños hacen suyo el espacio. Los papás sienten que llegaron al lugar correcto.' },
          { icono: '⚖️', color: 'var(--cafe)',    titulo: 'Flexibilidad sin caos',      desc: 'Nos adaptamos a cada familia. Con estructura, sin rigidez.' },
        ].map(v => (
          <div class="valor__card">
            <span class="valor__icono" style={`background: ${v.color}22; color: ${v.color}`}>{v.icono}</span>
            <h3>{v.titulo}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PROYECTO EDUCATIVO ── -->
  <section class="section section--crema">
    <div class="container">
      <div class="section__header">
        <span class="section__badge">Nuestro proyecto educativo</span>
        <h2 class="section__titulo">Orientando aprendizajes</h2>
      </div>

      <div class="proyecto__grid">
        <div class="proyecto__proposito">
          <h3>Propósito</h3>
          <p>
            En Rincón de Matías somos orientadoras del quehacer educativo, buscando estrategias
            que favorecen el desarrollo personal de cada niño y niña. Les entregamos las herramientas
            que nos permiten potenciar sus habilidades, aptitudes y motivaciones, incrementar
            aprendizajes y considerar una visión de proyección hacia sus próximos períodos escolares
            y su formación ciudadana.
          </p>
        </div>

        <div class="proyecto__beneficios">
          <h3>Lo que ofrecemos</h3>
          <ul class="proyecto__lista">
            {[
              {
                img: '/images/proyecto-educativo/icono-1.png',
                titulo: 'Desarrollo integral personalizado',
                desc: 'Aprendizajes adaptados al ritmo de cada niño, combinando actividades lúdicas, bienestar y socialización.',
              },
              {
                img: '/images/proyecto-educativo/icono-5.png',
                titulo: 'Ambiente seguro y estimulante',
                desc: 'Espacios diseñados para lograr aprendizajes significativos, con monitoreo constante y un equipo técnico-pedagógico comprometido.',
              },
              {
                img: '/images/proyecto-educativo/icono-2.png',
                titulo: 'Apoyo constante a la familia',
                desc: 'Horarios flexibles y adaptables, alimentación equilibrada y comunicación permanente con cada familia.',
              },
            ].map(b => (
              <li class="proyecto__item">
                <img class="proyecto__icono-img" src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${b.img}`} alt={b.titulo} />
                <div>
                  <strong>{b.titulo}</strong>
                  <p>{b.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="proyecto__valores">
        <div class="proyecto__valores-header">
          <h3>Viviendo nuestros valores</h3>
          <p>
            Durante más de 30 años hemos construido una comunidad educativa donde el respeto,
            la honestidad, la alegría, el compañerismo, la empatía, la responsabilidad, la tolerancia
            y la solidaridad son vivencias diarias que moldean el carácter de los niños mientras
            interactúan con sus pares y educadoras.
          </p>
        </div>
        <div class="proyecto__valores-grid">
          {[
            { icono: '🤝', valor: 'Respeto' },
            { icono: '😊', valor: 'Honestidad' },
            { icono: '🌟', valor: 'Alegría' },
            { icono: '👫', valor: 'Compañerismo' },
            { icono: '💛', valor: 'Empatía' },
            { icono: '⚖️', valor: 'Responsabilidad' },
            { icono: '🌈', valor: 'Tolerancia' },
            { icono: '🙌', valor: 'Solidaridad' },
          ].map(({ icono, valor }) => (
            <div class="proyecto__valor">
              <span>{icono}</span>
              <strong>{valor}</strong>
            </div>
          ))}
        </div>
        <div class="proyecto__valores-beneficios">
          {[
            { img: '/images/proyecto-educativo/icono-3.png', titulo: 'Formación integral en valores', desc: 'Desarrollo del carácter y habilidades sociales a través de experiencias significativas diarias.' },
            { img: '/images/proyecto-educativo/icono-6.png', titulo: 'Convivencia positiva', desc: 'Espacios seguros donde se practica el respeto y la empatía entre todos los miembros de la comunidad.' },
            { img: '/images/proyecto-educativo/icono-4.png', titulo: 'Aprendizaje social activo', desc: 'Experiencias educativas diseñadas para fortalecer el compañerismo, la responsabilidad y la solidaridad.' },
          ].map(b => (
            <div class="proyecto__vbenefit">
              <img class="proyecto__icono-img" src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${b.img}`} alt={b.titulo} />
              <div>
                <strong>{b.titulo}</strong>
                <p>{b.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Compromiso -->
    <div class="container">
    <div class="compromiso__grid" style="margin-top: 3rem">
      <div class="compromiso__texto">
        <span class="section__badge">Compromiso</span>
        <h3 style="margin-top: .75rem">Compromiso con la educación integral</h3>
        <p>
          En Rincón de Matías mantenemos el compromiso diario de potenciar la calidad de la educación,
          promoviendo la equidad y la pertinencia social y cultural en cada etapa del desarrollo infantil,
          a través de un enfoque educativo integral. Contamos con un Proyecto Educativo Institucional
          sólido que guía a todos los estamentos de nuestra comunidad educativa. Con este compromiso,
          buscamos formar niños autónomos, sensibles a su entorno y preparados para los desafíos del futuro.
        </p>
      </div>
      <div class="compromiso__items">
        {[
          { icono: '🎯', texto: 'Educación personalizada y de calidad, adaptada a las necesidades individuales de cada niño.' },
          { icono: '🌍', texto: 'Entorno inclusivo y equitativo, que respeta y valora la diversidad cultural y social.' },
          { icono: '📘', texto: 'Proyecto educativo integral que asegura experiencias significativas y aprendizaje constante.' },
        ].map(c => (
          <div class="compromiso__item">
            <span>{c.icono}</span>
            <p>{c.texto}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Desarrollo -->
    <div class="compromiso__grid" style="margin-top: 3rem; padding-top: 3rem; border-top: 1px dashed rgba(42,31,24,.1)">
      <div class="compromiso__texto">
        <span class="section__badge">Desarrollo</span>
        <h3 style="margin-top: .75rem">Creciendo con confianza</h3>
        <p>
          Fomentamos el desarrollo cognitivo, emocional y social de cada niño a través de experiencias
          significativas y planificadas, complementadas con recursos educativos de alta calidad.
          Evaluamos diariamente las actividades realizadas, asegurando aprendizajes fundamentales y
          detectando oportunidades para potenciar las habilidades de cada niño. Mantenemos comunicación
          constante con las familias, informándoles sobre los logros alcanzados y coordinando apoyo
          especializado cuando es necesario.
        </p>
      </div>
      <div class="compromiso__items">
        {[
          { icono: '🧠', texto: 'Aprendizaje personalizado, adaptado al ritmo y necesidades de cada niño.' },
          { icono: '📊', texto: 'Evaluaciones continuas que garantizan un progreso constante y significativo.' },
          { icono: '👨‍👩‍👧', texto: 'Colaboración con la familia, asegurando un apoyo integral y efectivo para los niños.' },
        ].map(c => (
          <div class="compromiso__item">
            <span>{c.icono}</span>
            <p>{c.texto}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Seguridad -->
    <div class="compromiso__grid" style="margin-top: 3rem; padding-top: 3rem; border-top: 1px dashed rgba(42,31,24,.1)">
      <div class="compromiso__texto">
        <span class="section__badge">Seguridad</span>
        <h3 style="margin-top: .75rem">Un entorno seguro para aprender y crecer</h3>
        <p>
          El equipo técnico-pedagógico trabaja para crear un entorno seguro y educativo que promueva
          el bienestar integral de cada niño y niña. Nuestro enfoque favorece la adaptación e integración
          al grupo, respetando su individualidad y potenciando un rol activo en su proceso de desarrollo.
          Diseñamos experiencias de aprendizaje significativas que incluyen la expresión artística,
          cultural y social, asegurando equidad y calidad en cada actividad. Fomentamos el respeto por
          la diversidad y fortalecemos habilidades motrices, culturales e históricas que enriquecen el
          aprendizaje integral.
        </p>
      </div>
      <div class="compromiso__items">
        {[
          { icono: '🛡️', texto: 'Entorno inclusivo y seguro, que respeta la individualidad de cada niño.' },
          { icono: '🌿', texto: 'Desarrollo integral con aprendizajes significativos y adaptados a sus etapas de crecimiento.' },
          { icono: '🎭', texto: 'Experiencias culturales y artísticas que enriquecen su conocimiento y habilidades.' },
        ].map(c => (
          <div class="compromiso__item">
            <span>{c.icono}</span>
            <p>{c.texto}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Recursos -->
    <div class="compromiso__grid" style="margin-top: 3rem; padding-top: 3rem; border-top: 1px dashed rgba(42,31,24,.1)">
      <div class="compromiso__texto">
        <span class="section__badge">Recursos</span>
        <h3 style="margin-top: .75rem">Servicios que fomentan el aprendizaje integral</h3>
        <p>
          Ofrecemos un entorno cuidadosamente diseñado para satisfacer las necesidades pedagógicas,
          recreativas y de juego de los niños. Proveemos todos los materiales necesarios para experiencias
          significativas, desde actividades psicomotrices hasta juegos y recreación. Contamos con espacios
          libres interiores y exteriores adecuados para explorar y aprender, complementados por tecnología
          como equipos de música, computación y multimedia que enriquecen el proceso educativo.
        </p>
      </div>
      <div class="compromiso__items">
        {[
          { icono: '📚', texto: 'Materiales educativos desafiantes y diversos, preparados para cada actividad pedagógica y recreativa.' },
          { icono: '🏡', texto: 'Espacios seguros y versátiles, ideales para el desarrollo integral de niños y niñas.' },
          { icono: '💻', texto: 'Tecnología educativa que potencia aprendizajes interactivos y creativos.' },
        ].map(c => (
          <div class="compromiso__item">
            <span>{c.icono}</span>
            <p>{c.texto}</p>
          </div>
        ))}
      </div>
    </div>
    </div><!-- /container -->

  </section>

  <!-- ── EQUIPO ── -->
  <section class="section section--crema2">
    <div class="container">
      <div class="section__header">
        <span class="section__badge">Quiénes somos</span>
        <h2 class="section__titulo">El equipo detrás del jardín</h2>
        <p class="section__subtitulo">
          Educadoras y técnicos que eligen este trabajo porque les importa, no porque les quedó cerca.
        </p>
      </div>
      <div class="equipo__grid">
        {[
          { nombre: 'Directora', rol: 'Dirección', desc: 'Al frente del jardín hace más de 15 años. Conoce a cada familia por nombre.' },
          { nombre: 'Educadora Sala Cuna', rol: 'Sala Cuna · 1er Ciclo', desc: 'Especialista en estimulación temprana. Referente para bebés de 3 meses a 2 años.' },
          { nombre: 'Educadora Jardín', rol: 'Jardín · 2do Ciclo', desc: 'Prepara a los niños para el colegio con metodología lúdica y afectiva.' },
          { nombre: 'Técnicos en Ed. Parvularia', rol: 'Apoyo en todos los ciclos', desc: 'Presentes en cada sala. La relación cotidiana con los niños pasa por ellos.' },
        ].map(e => (
          <div class="equipo__card">
            <div class="equipo__foto-placeholder" aria-hidden="true">📷</div>
            <div class="equipo__info">
              <strong>{e.nombre}</strong>
              <span class="equipo__rol">{e.rol}</span>
              <p>{e.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="equipo__nota">
        📷 <em>Las fotos del equipo serán incorporadas por el jardín antes del lanzamiento.</em>
      </p>
    </div>
  </section>

  <!-- ── ESPACIOS ── -->
  <section class="section section--cafe">
    <div class="container">
      <div class="section__header">
        <span class="section__badge" style="background: var(--amarillo); color: var(--cafe)">Nuestros espacios</span>
        <h2 class="section__titulo" style="color: var(--crema)">Cuatro salas. Un patio para cada historia.</h2>
        <p class="section__subtitulo" style="color: rgba(255,247,232,.6)">
          Cada sala tiene nombre propio. Igual que los niños que la habitan.
        </p>
      </div>
      <div class="salas__grid">
        {[
          { nombre: 'Sala Lilén',      ciclo: 'Sala Cuna',            color: 'var(--rosa)',    img: '/images/infraestructura/sala-lilen.jpg',        desc: 'Para los más pequeños. Cálida, segura, diseñada para la estimulación temprana.' },
          { nombre: 'Sala Palmera',   ciclo: 'Jardín Infantil',      color: 'var(--azul)',   img: '/images/infraestructura/sala-palmera.jpg',      desc: 'Espacio de exploración, aprendizaje y movimiento libre.' },
          { nombre: 'Patio Central',  ciclo: 'Todos los ciclos',     color: 'var(--verde)',  img: '/images/infraestructura/patio-central.jpg',     desc: 'El corazón del jardín. Espacio para correr, jugar y compartir.' },
          { nombre: 'Patio Arena',    ciclo: 'Psicomotricidad',      color: 'var(--naranja)', img: '/images/infraestructura/patio-psicomotricidad.jpg', desc: 'Área de psicomotricidad y juego sensorial al aire libre.' },
        ].map(s => (
          <div class="sala__card" style={`border-top: 5px solid ${s.color}`}>
            <img class="sala__img" src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${s.img}`} alt={s.nombre} loading="lazy" />
            <div class="sala__info">
              <span class="sala__ciclo" style={`color: ${s.color}`}>{s.ciclo}</span>
              <h3>{s.nombre}</h3>
              <p>{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="section section--crema" style="text-align:center">
    <div class="container">
      <h2 class="section__titulo">¿Quieres conocernos en persona?</h2>
      <p class="section__subtitulo" style="margin: 0 auto 2rem">
        Una visita de 30 minutos vale más que cualquier página web.
      </p>
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/contacto#agendar`} class="btn btn--naranja">Agendar visita →</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero {
    background: var(--crema-2);
    padding-top: calc(var(--nav-h) + 1.5rem);
    padding-bottom: 4rem;
  }
  .page-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .page-hero__h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: .75rem 0 1rem;
  }
  .page-hero__sub {
    font-size: 1.05rem;
    opacity: .75;
    max-width: 44ch;
  }
  .page-hero__img img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    object-fit: cover;
    aspect-ratio: 4/3;
  }

  /* Historia */
  .historia {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .historia__texto p {
    margin-bottom: 1rem;
    opacity: .8;
    line-height: 1.7;
  }
  .historia__texto .section__badge { margin-bottom: .75rem; }
  .historia__texto .section__titulo { margin-bottom: 1.25rem; }

  .historia__hitos { display: flex; flex-direction: column; gap: 1rem; padding-top: .5rem; }
  .historia__hito {
    display: grid;
    grid-template-columns: 56px 24px 1fr;
    align-items: center;
    gap: .5rem;
  }
  .historia__año {
    font-family: var(--font-titulo);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--naranja);
    text-align: right;
  }
  .historia__linea {
    width: 2px;
    height: 100%;
    min-height: 20px;
    background: var(--naranja);
    margin-inline: auto;
  }
  .historia__hito p { font-size: .95rem; opacity: .8; }

  /* Valores */
  .valores__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .valor__card {
    background: var(--crema-2);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
    box-shadow: var(--shadow);
  }
  .valor__icono {
    display: inline-grid;
    place-items: center;
    width: 48px; height: 48px;
    border-radius: 50%;
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }
  .valor__card h3 { font-size: 1rem; margin-bottom: .4rem; }
  .valor__card p  { font-size: .875rem; opacity: .7; line-height: 1.55; }

  /* Equipo */
  .equipo__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .equipo__card {
    background: var(--crema);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .equipo__foto-placeholder {
    aspect-ratio: 1;
    background: var(--crema-2);
    display: grid;
    place-items: center;
    font-size: 2.5rem;
    border-bottom: 1px solid rgba(42,31,24,.06);
  }
  .equipo__info { padding: 1.25rem; }
  .equipo__info strong { display: block; font-family: var(--font-titulo); font-size: 1rem; }
  .equipo__rol { display: block; font-size: .8rem; color: var(--naranja); margin: .2rem 0 .6rem; }
  .equipo__info p { font-size: .85rem; opacity: .7; line-height: 1.5; }
  .equipo__nota { text-align: center; font-size: .85rem; opacity: .5; }

  /* Salas */
  .salas__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  .sala__card {
    background: rgba(255,247,232,.07);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid rgba(255,247,232,.1);
  }
  .sala__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid rgba(255,247,232,.08);
  }
  .sala__info { padding: 1.25rem; }
  .sala__ciclo { font-size: .8rem; font-weight: 600; margin-bottom: .3rem; display: block; }
